{
  "name": "ddd-documentation-first",
  "displayName": "Documentation First - DDD2",
  "description": "Make your documentation a superpower contextual memory for your AI agent. Documentation-Driven Development (DDD) v2 for agentic AI — a superset of Spec-Driven Development (SDD) that hosts and versions your specs.",
  "version": "1.0.3",
  "publisher": "DocumentationFirst",
  "author": "Documentation First <contact@documentationfirst.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/documentationfirst/plugin-vscode"
  },
  "homepage": "https://documentationfirst.ai",
  "icon": "assets/ddd-ai-marketplace.png",
  "galleryBanner": {
    "color": "#2d2d2d",
    "theme": "dark"
  },
  "files": [
    "dist/*",
    "assets/icon.svg",
    "assets/ddd-ai-marketplace.png",
    "LICENSE.txt"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "documentation",
    "ai",
    "ddd",
    "documentation-driven",
    "context",
    "markdown",
    "agent",
    "specification",
    "sdd",
    "spec-driven",
    "spec-driven-development",
    "spec-kit",
    "knowledge-base",
    "best-practices",
    "development",
    "templates"
  ],
  "activationEvents": [
    "workspaceContains:**/.ai_context/**",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ddd.initContext",
        "title": "Documentation First: Initialize Context",
        "icon": "$(add)"
      },
      {
        "command": "ddd.newVision",
        "title": "Documentation First: New Vision",
        "icon": "$(refresh)"
      },
      {
        "command": "ddd.newTask",
        "title": "Documentation First: New Tasks",
        "icon": "$(tasklist)"
      },
      {
        "command": "ddd.newDocument",
        "title": "Documentation First: New Document",
        "icon": "$(file-add)"
      },
      {
        "command": "ddd.newSkill",
        "title": "Documentation First: New Skill",
        "icon": "$(mortar-board)"
      },
      {
        "command": "ddd.togglePermanent",
        "title": "Documentation First: Toggle Permanent",
        "icon": "$(bookmark)"
      },
      {
        "command": "ddd.refresh",
        "title": "Documentation First: Refresh",
        "icon": "$(sync)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ddd-sidebar",
          "title": "Documentation First",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "ddd-sidebar": [
        {
          "id": "dddExplorer",
          "name": "Documents",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "dddContextPanel",
          "type": "webview",
          "name": "Context",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "ddd.newDocument",
          "when": "view == dddExplorer && viewItem == dddFolder",
          "group": "inline"
        },
        {
          "command": "ddd.newSkill",
          "when": "view == dddExplorer && viewItem == dddSkillsFolder",
          "group": "inline"
        },
        {
          "command": "ddd.togglePermanent",
          "when": "view == dddExplorer && viewItem == dddPermanentEligibleFile",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile:prod",
    "compile": "node esbuild.mjs",
    "compile:prod": "NODE_ENV=production node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package",
    "publish": "vsce publish",
    "test": "vscode-test",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^2.26.0",
    "esbuild": "^0.21.0",
    "eslint": "^9.39.4",
    "typescript": "^5.4.0"
  }
}
